<?xml version="1.0" encoding="utf-8"?>
<androidx.slidingpanelayout.widget.SlidingPaneLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/slidingPaneLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Main content pane (video + controls) -->
    <FrameLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <SurfaceView
            android:id="@+id/surfaceView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/textViewSeekFeedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#88000000"
            android:padding="24dp"
            android:textColor="@android:color/white"
            android:textSize="48sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/controlsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#80000000"
            android:orientation="vertical"
            android:padding="16dp">

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@android:color/white"
                android:thumbTint="@android:color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textViewCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@android:color/white" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/buttonPrevious"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_previous"
                    app:tint="@android:color/white"
                    android:contentDescription="Previous" />

                <ImageButton
                    android:id="@+id/buttonPlayPause"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_play"
                    app:tint="@android:color/white"
                    android:contentDescription="Play/Pause" />

                <ImageButton
                    android:id="@+id/buttonNext"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_next"
                    app:tint="@android:color/white"
                    android:contentDescription="Next" />

                <ImageButton
                    android:id="@+id/buttonSpeed"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_speed"
                    app:tint="@android:color/white"
                    android:contentDescription="Playback speed" />

                <ImageButton
                    android:id="@+id/buttonSnapshot"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_screenshot"
                    app:tint="@android:color/white"
                    android:contentDescription="Take screenshot" />

                <ImageButton
                    android:id="@+id/buttonOpenPanel"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_list"
                    app:tint="@android:color/white"
                    android:contentDescription="Video list" />

                <ImageButton
                    android:id="@+id/buttonLock"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_lock"
                    app:tint="@android:color/white"
                    android:contentDescription="Lock rotation" />

                <ImageButton
                    android:id="@+id/buttonSleepTimer"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_timer"
                    app:tint="@android:color/white"
                    android:contentDescription="Sleep timer" />

                <ImageButton
                    android:id="@+id/buttonBookmark"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_bookmark"
                    app:tint="@android:color/white"
                    android:contentDescription="Bookmarks" />

                <ImageButton
                    android:id="@+id/buttonInfo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_info"
                    app:tint="@android:color/white"
                    android:contentDescription="Video info" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/textViewTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@android:color/white" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/textViewDebug"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:textColor="#00FF00"
            android:textSize="10sp"
            android:padding="8dp"
            android:background="#88000000" />

    </FrameLayout>

    <!-- Quick list pane (Fragment) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/quickListContainer"
        android:name="com.simplevlc.ui.quicklist.QuickListFragment"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#2A2A2A"
        android:elevation="8dp" />

</androidx.slidingpanelayout.widget.SlidingPaneLayout>
